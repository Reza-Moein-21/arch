{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 10,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": [],
  "modules-right": ["pulseaudio", "network", "cpu", "memory", "clock", "tray"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate",
    "sort-by-number": true
  },

  "clock": {
    "format": "{:%I:%M %p}"
  },

  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": "󰈀 Wired",
    "format-disconnected": "󰖪 Offline"
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " muted"
  },

  "cpu": {
    "format": " {usage}%"
  },

  "memory": {
    "format": " {percentage}%"
  }
}
